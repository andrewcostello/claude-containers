# Environment secrets passed into all containers.
# Copy to secrets.env and fill in your values:
#   cp secrets.example.env secrets.env
#
# Or run: ./setup-project.sh to configure interactively.
#
# These are passed via --env-file to docker run.

# Claude Code OAuth token (valid 1 year)
# Generate with: claude-in-container --login <project>
CLAUDE_CODE_OAUTH_TOKEN=

# Jira API token (used by forecast CLI)
# Generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=

# Figma Personal Access Token (enables Figma MCP in containers)
# Generate at: Figma → Account Settings → Personal Access Tokens
FIGMA_API_KEY=
