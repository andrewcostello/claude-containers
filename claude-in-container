#!/usr/bin/env bash
set -euo pipefail

IMAGE_NAME="claude-dev"
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

# Windows (Git Bash / MSYS2) support
IS_WINDOWS=false
if [[ "$(uname -o 2>/dev/null)" == "Msys" ]]; then
    IS_WINDOWS=true
    export MSYS_NO_PATHCONV=1
fi

# Convert MSYS paths (/c/Users/...) to Windows paths (C:/Users/...) for Docker mounts.
# On Linux this is a no-op. Docker Desktop on Windows needs C:/ style paths.
winpath() {
    if [[ "$IS_WINDOWS" == "true" ]]; then
        echo "$1" | sed -E 's|^/([a-zA-Z])/|\U\1:/|'
    else
        echo "$1"
    fi
}

# Load machine-specific config
if [[ -f "$SCRIPT_DIR/config.sh" ]]; then
    source "$SCRIPT_DIR/config.sh"
else
    echo "Error: config.sh not found. Copy config.example.sh to config.sh and customize." >&2
    echo "  cp $SCRIPT_DIR/config.example.sh $SCRIPT_DIR/config.sh" >&2
    exit 1
fi

# Configurable defaults (override in config.sh)
CONTAINER_MEMORY="${CONTAINER_MEMORY:-8g}"
CONTAINER_CPUS="${CONTAINER_CPUS:-4}"
MOUNT_DOCKER_SOCKET="${MOUNT_DOCKER_SOCKET:-false}"

usage() {
    echo "Usage: claude-in-container [flags] <project> [claude args...]"
    echo ""
    echo "Projects:"
    for key in "${!PROJECTS[@]}"; do
        echo "  $key  ->  ${PROJECTS[$key]}"
    done
    echo ""
    echo "Examples:"
    echo "  claude-in-container rr"
    echo "  claude-in-container evenplay 'fix the login bug'"
    echo "  claude-in-container --docker evenplay   # mount Docker socket"
    echo ""
    echo "Modifier flags (combine before command/project):"
    echo "  --docker                 Mount Docker socket (for devcontainers)"
    echo "  --host-network           Use host network (for tilt/k8s port-forwards)"
    echo "  --offline                Disable network access"
    echo ""
    echo "Commands:"
    echo "  claude-in-container --build                Rebuild the Docker image"
    echo "  claude-in-container --login <project>      Run claude auth login in the container"
    echo "  claude-in-container --shell <project>      Open a bash shell in the container"
    echo "  claude-in-container --worktree <project> <name>  Spawn instance on a new git worktree"
    echo "  claude-in-container --list                 List running claude containers"
    echo "  claude-in-container --stop <project> <name>  Stop worktree + clean up everything"
    echo "  claude-in-container --prune <project>      Remove all stale worktrees and branches"
    echo ""
    echo "Multiple instances:"
    echo "  claude-in-container --worktree evenplay wallet-fix"
    echo "  claude-in-container --worktree evenplay auth-refactor"
    echo ""
    echo "PR review (URL or shorthand):"
    echo "  claude-in-container --worktree evenplay pr-42"
    echo "  claude-in-container --review https://github.com/org/repo/pull/42"
    exit 1
}

build_image() {
    echo "Building $IMAGE_NAME image..."
    local host_uid host_gid docker_gid build_context
    if [[ "$IS_WINDOWS" == "true" ]]; then
        host_uid=1000
        host_gid=1000
        docker_gid=999
        build_context="$(winpath "$SCRIPT_DIR")"
    else
        host_uid="$(id -u)"
        host_gid="$(id -g)"
        docker_gid="$(getent group docker | cut -d: -f3)"
        build_context="$SCRIPT_DIR"
    fi
    docker build \
        --build-arg HOST_UID="$host_uid" \
        --build-arg HOST_GID="$host_gid" \
        --build-arg DOCKER_GID="$docker_gid" \
        -t "$IMAGE_NAME" \
        "$build_context"
}

ensure_image() {
    if ! docker image inspect "$IMAGE_NAME" &>/dev/null; then
        echo "Image $IMAGE_NAME not found, building..."
        build_image
    fi
}

resolve_project() {
    local key="$1"
    if [[ -n "${PROJECTS[$key]+x}" ]]; then
        echo "${PROJECTS[$key]}"
    else
        echo "Unknown project: $key" >&2
        echo "" >&2
        usage
    fi
}

# Find the project key whose origin matches a given GitHub owner/repo.
# Falls back to cloning the repo and registering it as a temporary project.
find_or_clone_project() {
    local owner="$1" repo="$2"
    local match_url="github.com/${owner}/${repo}"

    # Check configured projects for a matching remote
    for key in "${!PROJECTS[@]}"; do
        local dir="$PROJECTS_DIR/${PROJECTS[$key]}"
        [[ -d "$dir/.git" || -f "$dir/.git" ]] || continue
        local remote_url
        remote_url=$(git -C "$dir" remote get-url origin 2>/dev/null) || continue
        if [[ "$remote_url" == *"$match_url"* ]]; then
            echo "$key"
            return
        fi
    done

    # Not found — look for an existing clone at PROJECTS_DIR/<repo>
    local clone_dir="$PROJECTS_DIR/$repo"
    if [[ -d "$clone_dir/.git" ]]; then
        local remote_url
        remote_url=$(git -C "$clone_dir" remote get-url origin 2>/dev/null) || true
        if [[ "$remote_url" == *"$match_url"* ]]; then
            # Register as a runtime project so the rest of the script works
            PROJECTS["$repo"]="$repo"
            echo "$repo"
            return
        fi
    fi

    # Clone it fresh
    echo "Cloning ${owner}/${repo} into $clone_dir..." >&2
    git clone "https://github.com/${owner}/${repo}.git" "$clone_dir" >&2
    PROJECTS["$repo"]="$repo"
    echo "$repo"
}

prune_worktrees() {
    local project_key="$1"
    local project_dir
    project_dir="$(resolve_project "$project_key")"
    local full_path="$PROJECTS_DIR/$project_dir"

    if [[ ! -d "$full_path" ]]; then
        echo "Error: project directory $full_path does not exist" >&2
        exit 1
    fi

    echo "Pruning stale worktrees for $project_key..."

    # Let git clean up any worktrees whose directories were already removed
    git -C "$full_path" worktree prune

    # Find worktree directories matching this project's pattern
    local wt_prefix="$PROJECTS_DIR/${project_dir}-wt-"
    local found=0
    for wt_path in "${wt_prefix}"*/; do
        [[ -d "$wt_path" ]] || continue
        found=1
        local wt_name
        wt_name=$(basename "$wt_path")
        local branch="${wt_name#"${project_dir}-wt-"}"

        # Check if there's a running container for this worktree
        local container_name="claude-${project_key}-${branch}"
        if docker ps --format '{{.Names}}' | grep -q "^${container_name}$"; then
            echo "  SKIP  $wt_name (container running)"
            continue
        fi

        read -r -p "  Remove worktree $wt_name and branch $branch? [y/N] " answer </dev/tty
        if [[ "${answer,,}" == "y" ]]; then
            git -C "$full_path" worktree remove "$wt_path" 2>/dev/null \
                || rm -rf "$wt_path" 2>/dev/null \
                || sudo rm -rf "$wt_path"
            git -C "$full_path" branch -d "$branch" 2>/dev/null \
                && echo "    Removed worktree + branch: $branch" \
                || echo "    Removed worktree (branch $branch not fully merged, kept)"
            # Clean up instance config volume
            local vol_name="claude-config-${project_key}-${branch}"
            docker volume rm "$vol_name" 2>/dev/null \
                && echo "    Removed volume: $vol_name" || true
        fi
    done

    if [[ $found -eq 0 ]]; then
        echo "  No worktrees found for $project_key"
    fi
}

stop_worktree() {
    local project_key="$1"
    local instance="$2"
    local project_dir
    project_dir="$(resolve_project "$project_key")"
    local full_path="$PROJECTS_DIR/$project_dir"
    local container_name="claude-${project_key}-${instance}"
    local wt_path="$PROJECTS_DIR/${project_dir}-wt-${instance}"
    local vol_name="claude-config-${project_key}-${instance}"

    # Stop container if running
    if docker ps --format '{{.Names}}' | grep -q "^${container_name}$"; then
        echo "Stopping container $container_name..."
        docker stop "$container_name" >/dev/null 2>&1 || true
    fi

    # Remove worktree directory
    if [[ -d "$wt_path" ]]; then
        echo "Removing worktree $wt_path..."
        git -C "$full_path" worktree remove "$wt_path" 2>/dev/null \
            || rm -rf "$wt_path" 2>/dev/null \
            || sudo rm -rf "$wt_path"
    fi

    # Prune git worktree references
    git -C "$full_path" worktree prune 2>/dev/null || true

    # Delete branch (warn if not merged)
    if git -C "$full_path" rev-parse --verify "$instance" &>/dev/null; then
        git -C "$full_path" branch -d "$instance" 2>/dev/null \
            && echo "Deleted branch: $instance" \
            || echo "Branch $instance not fully merged (kept). Use 'git branch -D $instance' to force-delete."
    fi

    # Remove instance config volume
    if docker volume inspect "$vol_name" &>/dev/null; then
        echo "Removing volume $vol_name..."
        docker volume rm "$vol_name" >/dev/null 2>&1 || true
    fi

    echo "Done."
}

list_containers() {
    local containers
    containers=$(docker ps --filter "name=claude-" --format "{{.Names}}|{{.Status}}|{{.RunningFor}}" 2>/dev/null)

    if [[ -z "$containers" ]]; then
        echo "No running claude containers."
        return
    fi

    # Header
    printf "\033[1m%-30s %-20s %s\033[0m\n" "CONTAINER" "STATUS" "RUNNING"
    echo "────────────────────────────────────────────────────────────────"

    while IFS='|' read -r name status running; do
        # Extract project key from container name (claude-<project>[-instance])
        local project_key="${name#claude-}"
        local base_project="${project_key%%-*}"
        local hash_val
        hash_val=$(printf '%s' "$base_project" | cksum | cut -d' ' -f1)
        local color_code=$(( (hash_val % 6) + 31 ))

        printf "\033[1;${color_code}m%-30s\033[0m %-20s %s\n" "$name" "$status" "$running"
    done <<< "$containers"
}

run_container() {
    local project_key="$1"
    shift
    local project_dir
    project_dir="$(resolve_project "$project_key")"
    local full_path="$PROJECTS_DIR/$project_dir"

    if [[ ! -d "$full_path" ]]; then
        echo "Error: project directory $full_path does not exist" >&2
        exit 1
    fi

    ensure_image

    # Instance name — default or worktree-specific
    local instance="${INSTANCE_NAME:-}"
    local container_name="claude-${project_key}${instance:+-$instance}"

    # Base project gets claude-config-<project>. Worktree instances get their
    # own volume (claude-config-<project>-<instance>) to avoid session conflicts.
    # The base volume is also mounted read-only at ~/.claude-base so the
    # entrypoint can clone auth+settings into fresh instance volumes.
    local base_config_vol="claude-config-${project_key}"
    local config_vol="claude-config-${project_key}${instance:+-$instance}"

    # If worktree mode, create a worktree branched from main (fresh)
    if [[ "${MODE:-}" == "worktree" ]] && [[ -n "$instance" ]]; then
        local wt_path="$PROJECTS_DIR/${project_dir}-wt-${instance}"
        if [[ ! -d "$wt_path" ]]; then
            # Fetch latest first
            echo "Fetching latest from origin..."
            git -C "$full_path" fetch origin 2>/dev/null || true

            # If instance looks like a PR reference (PR-123, PR123, pr-123, etc.),
            # resolve the PR's head branch and check that out instead
            local pr_number=""
            local pr_branch=""
            if [[ "$instance" =~ ^[Pp][Rr]-?([0-9]+)$ ]]; then
                pr_number="${BASH_REMATCH[1]}"
                echo "Resolving PR #${pr_number} branch..."
                pr_branch=$(gh pr view "$pr_number" \
                    --repo "$(git -C "$full_path" remote get-url origin)" \
                    --json headRefName --jq '.headRefName' 2>&1) \
                    || { echo "Error: could not resolve PR #${pr_number}: $pr_branch"; exit 1; }
                echo "PR #${pr_number} -> branch: $pr_branch"
                git -C "$full_path" fetch origin "$pr_branch" 2>/dev/null || true
                echo "Creating worktree: $wt_path (tracking PR #${pr_number} branch: $pr_branch)"
                git -C "$full_path" worktree add "$wt_path" -b "$instance" "origin/$pr_branch" 2>/dev/null \
                    || git -C "$full_path" worktree add "$wt_path" "origin/$pr_branch"
                PR_REVIEW_NUM="$pr_number"
            else
                echo "Creating worktree: $wt_path (branch: $instance from origin/main)"
                git -C "$full_path" worktree add "$wt_path" -b "$instance" origin/main 2>/dev/null \
                    || git -C "$full_path" worktree add "$wt_path" "$instance"
            fi
        else
            echo "Using existing worktree: $wt_path"
            # Still detect PR pattern for role injection on reuse
            if [[ "$instance" =~ ^[Pp][Rr]-?([0-9]+)$ ]]; then
                PR_REVIEW_NUM="${BASH_REMATCH[1]}"
            fi
        fi
        full_path="$wt_path"
    fi

    local extra_flags=()

    # Handle special modes
    if [[ "${MODE:-}" == "login" ]]; then
        # Generate a long-lived OAuth token and add it to secrets.env
        extra_flags+=("--entrypoint" "entrypoint.sh")
        set -- "setup-token"
        echo "Tip: Add the generated token to secrets.env as CLAUDE_CODE_OAUTH_TOKEN=<token>"
    elif [[ "${MODE:-}" == "shell" ]]; then
        extra_flags+=("--entrypoint" "/bin/bash")
        set --
    else
        # Prompt for permission mode (default: skip permissions since it's containerized)
        read -r -p "Skip permissions? [Y/n] " answer </dev/tty
        if [[ "${answer,,}" != "n" ]]; then
            set -- --dangerously-skip-permissions "$@"
        fi
    fi

    # Mount host credentials read-only (shared across all projects)
    local host_mounts=()

    # Git config
    [[ -f "$HOME/.gitconfig" ]] && \
        host_mounts+=(-v "$(winpath "$HOME/.gitconfig")":/home/claude/.gitconfig:ro)

    # SSH keys (for git over SSH)
    [[ -d "$HOME/.ssh" ]] && \
        host_mounts+=(-v "$(winpath "$HOME/.ssh")":/home/claude/.ssh:ro)

    # GitHub CLI auth — token file takes priority, falls back to config dir
    # Create token file with: gh auth token > ~/.config/gh/token
    if [[ -f "$HOME/.config/gh/token" ]]; then
        host_mounts+=(-e "GH_TOKEN=$(cat "$HOME/.config/gh/token")")
    fi
    [[ -d "$HOME/.config/gh" ]] && \
        host_mounts+=(-v "$(winpath "$HOME/.config/gh")":/home/claude/.config/gh:ro)

    # Gemini CLI auth (OAuth credentials)
    [[ -d "$HOME/.gemini" ]] && \
        host_mounts+=(-v "$(winpath "$HOME/.gemini")":/home/claude/.gemini:ro)

    # OpenAI Codex CLI auth
    [[ -d "$HOME/.codex" ]] && \
        host_mounts+=(-v "$(winpath "$HOME/.codex")":/home/claude/.codex:ro)

    # Docker socket (only when explicitly requested — it grants host-level access)
    # Enable via: --docker flag, MOUNT_DOCKER_SOCKET=true, or per-project DOCKER_PROJECTS
    local needs_docker="${DOCKER_SOCKET}"
    if [[ "$needs_docker" != "true" ]] && declare -p DOCKER_PROJECTS &>/dev/null; then
        for dp in "${DOCKER_PROJECTS[@]}"; do
            [[ "$dp" == "$project_key" ]] && needs_docker=true && break
        done
    fi
    if [[ "$needs_docker" == "true" ]]; then
        if [[ "$IS_WINDOWS" == "true" ]]; then
            host_mounts+=(-v //var/run/docker.sock:/var/run/docker.sock)
        else
            [[ -S /var/run/docker.sock ]] && \
                host_mounts+=(-v /var/run/docker.sock:/var/run/docker.sock)
        fi
        [[ -d "$HOME/.docker" ]] && \
            host_mounts+=(-v "$(winpath "$HOME/.docker")":/home/claude/.docker:ro)
    fi

    # GCloud (if present)
    [[ -d "$HOME/.config/gcloud" ]] && \
        host_mounts+=(-v "$(winpath "$HOME/.config/gcloud")":/home/claude/.config/gcloud:ro)

    # AWS — config/credentials read-only, SSO/CLI cache read-write (shared
    # across host + all containers so you only run `aws sso login` once)
    if [[ -d "$HOME/.aws" ]]; then
        [[ -f "$HOME/.aws/config" ]] && \
            host_mounts+=(-v "$(winpath "$HOME/.aws/config")":/home/claude/.aws/config:ro)
        [[ -f "$HOME/.aws/credentials" ]] && \
            host_mounts+=(-v "$(winpath "$HOME/.aws/credentials")":/home/claude/.aws/credentials:ro)
        mkdir -p "$HOME/.aws/cli/cache" "$HOME/.aws/sso/cache"
        host_mounts+=(-v "$(winpath "$HOME/.aws/cli/cache")":/home/claude/.aws/cli/cache)
        host_mounts+=(-v "$(winpath "$HOME/.aws/sso/cache")":/home/claude/.aws/sso/cache)
    fi

    # SSH agent forwarding (if running)
    if [[ "$IS_WINDOWS" != "true" ]] && [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
        host_mounts+=(-v "$SSH_AUTH_SOCK":/tmp/ssh-agent.sock)
        host_mounts+=(-e SSH_AUTH_SOCK=/tmp/ssh-agent.sock)
    fi

    # Shared Claude roles (read-only)
    local roles_mounts=()
    if [[ -d "$ROLES_DIR" ]]; then
        roles_mounts+=(-v "$(winpath "$ROLES_DIR")":/workspace/.claude/roles:ro)
    fi

    # Forecast CLI — mount binary + per-project config
    local forecast_mounts=()
    local forecast_bin="${FORECAST_BIN:-}"
    if [[ -n "$forecast_bin" && -f "$forecast_bin" ]]; then
        forecast_mounts+=(-v "$(winpath "$forecast_bin")":/usr/local/bin/forecast:ro)
        # Mount project-specific .forecast config if it exists
        # Always use the main repo path (worktrees won't have .forecast since it's gitignored)
        local forecast_cfg="$PROJECTS_DIR/$project_dir/.forecast"
        if [[ -d "$forecast_cfg" ]]; then
            forecast_mounts+=(-v "$(winpath "$forecast_cfg")":/workspace/.forecast:ro)
        fi
    fi

    # If workspace is a git worktree, the .git file contains an absolute path
    # back to the main repo's .git dir. Mount it at the same absolute path
    # so the reference resolves inside the container.
    local git_mounts=()
    if [[ -f "$full_path/.git" ]]; then
        local main_git_dir
        main_git_dir=$(cd "$full_path" && git rev-parse --git-common-dir 2>/dev/null)
        if [[ -n "$main_git_dir" && -d "$main_git_dir" ]]; then
            main_git_dir=$(cd "$full_path" && cd "$main_git_dir" && pwd)
            # Mount at the same absolute path so worktree gitdir references work
            git_mounts+=(-v "$(winpath "$main_git_dir")":"$main_git_dir")
        fi
    fi

    # Secrets env file (JIRA_API_TOKEN, etc.)
    local secrets_env_flag=()
    if [[ -f "$SCRIPT_DIR/secrets.env" ]]; then
        secrets_env_flag+=(--env-file "$(winpath "$SCRIPT_DIR/secrets.env")")
    fi

    # Shared cache volumes (persist across container restarts)
    local cache_mounts=(
        -v claude-cache-npm:/home/claude/.npm
        -v claude-cache-go:/home/claude/go/pkg/mod
        -v claude-cache-pip:/home/claude/.cache/pip
        -v claude-cache-playwright:/home/claude/.cache/ms-playwright
    )

    # Kubernetes — mount kube config + minikube certs at the same absolute
    # paths so cert references in kubeconfig resolve inside the container.
    # Config is read-write because minikube/kubectl need to update contexts.
    if [[ "${HOST_NETWORK}" == "true" || "${DOCKER_SOCKET}" == "true" ]]; then
        [[ -f "$HOME/.kube/config" ]] && \
            host_mounts+=(-v "$(winpath "$HOME/.kube/config")":/home/claude/.kube/config)
        [[ -d "$HOME/.minikube" ]] && \
            host_mounts+=(-v "$(winpath "$HOME/.minikube")":"$HOME/.minikube":ro)
    fi

    # Minikube docker-env (for Tilt to discover minikube's Docker daemon)
    local minikube_flags=()
    if [[ "${HOST_NETWORK}" == "true" ]] && command -v minikube &>/dev/null; then
        # Start minikube if it isn't running
        if ! minikube status --format='{{.Host}}' 2>/dev/null | grep -q Running; then
            echo "Starting minikube..."
            minikube start
        fi

        local mk_env
        mk_env=$(minikube docker-env 2>/dev/null) || true
        if [[ -n "$mk_env" ]] && echo "$mk_env" | grep -q DOCKER_HOST; then
            local mk_host mk_cert mk_ip mk_ver
            mk_host=$(echo "$mk_env" | grep DOCKER_HOST | sed 's/.*"\(.*\)"/\1/')
            mk_cert=$(echo "$mk_env" | grep DOCKER_CERT_PATH | sed 's/.*"\(.*\)"/\1/')
            mk_ip=$(minikube ip 2>/dev/null || echo "192.168.49.2")
            mk_ver=$(minikube version --short 2>/dev/null || echo "v1.38.0")
            minikube_flags+=(
                -e "MINIKUBE_DOCKER_HOST=$mk_host"
                -e "MINIKUBE_CERT_PATH=$mk_cert"
                -e "MINIKUBE_IP=$mk_ip"
                -e "MINIKUBE_VERSION=$mk_ver"
            )
        fi
    fi

    # Network mode
    local network_flags=()
    if [[ "${HOST_NETWORK}" == "true" ]]; then
        network_flags+=(--network host)
    elif [[ "${OFFLINE}" == "true" ]]; then
        network_flags+=(--network none)
    fi

    # Stop and remove any existing container with the same name
    docker rm -f "$container_name" &>/dev/null || true

    # Build claude args: if this is a PR worktree and user didn't pass their
    # own args, auto-inject the pr_reviewer role and a review prompt
    local claude_args=("$@")
    if [[ -n "${PR_REVIEW_NUM:-}" ]] && [[ ${#claude_args[@]} -eq 0 ]]; then
        local role_file="${ROLES_DIR:-}/pr_reviewer.md"
        if [[ -f "$role_file" ]]; then
            local role_content
            role_content=$(<"$role_file")
            claude_args+=(
                "--append-system-prompt" "$role_content"
                "Review PR #${PR_REVIEW_NUM}. Start by reading the PR description and diff."
            )
            echo "Auto-loading pr_reviewer role for PR #${PR_REVIEW_NUM}"
        else
            claude_args+=("Review PR #${PR_REVIEW_NUM}. Start by reading the PR description and diff.")
            echo "Note: no pr_reviewer role found at $role_file — using default prompt"
        fi
    fi

    exec docker run --rm -it \
        --name "$container_name" \
        --hostname "claude-${project_key}" \
        --add-host "claude-${project_key}:127.0.0.1" \
        --memory "$CONTAINER_MEMORY" \
        --cpus "$CONTAINER_CPUS" \
        --tmpfs /worktrees:exec \
        -v "$(winpath "$full_path")":/workspace \
        "${git_mounts[@]}" \
        -v "${config_vol}":/home/claude/.claude \
        -v "${base_config_vol}":/home/claude/.claude-base:ro \
        "${cache_mounts[@]}" \
        "${host_mounts[@]}" \
        "${roles_mounts[@]}" \
        "${forecast_mounts[@]}" \
        ${secrets_env_flag[@]+"${secrets_env_flag[@]}"} \
        ${network_flags[@]+"${network_flags[@]}"} \
        ${minikube_flags[@]+"${minikube_flags[@]}"} \
        -e TERM="${TERM:-xterm-256color}" \
        -e CLAUDE_PROJECT="${project_key}" \
        "${extra_flags[@]}" \
        "$IMAGE_NAME" \
        "${claude_args[@]}"
}

# --- Main ---

if [[ $# -eq 0 ]]; then
    usage
fi

# Parse modifier flags (before command/project)
DOCKER_SOCKET="${MOUNT_DOCKER_SOCKET:-false}"
HOST_NETWORK=false
OFFLINE=false
while [[ $# -gt 0 ]]; do
    case "$1" in
        --docker) DOCKER_SOCKET=true; shift ;;
        --host-network) HOST_NETWORK=true; DOCKER_SOCKET=true; shift ;;
        --offline) OFFLINE=true; shift ;;
        *) break ;;
    esac
done

if [[ $# -eq 0 ]]; then
    usage
fi

case "$1" in
    --build)
        build_image
        ;;
    --login)
        [[ $# -lt 2 ]] && usage
        MODE=login run_container "$2"
        ;;
    --shell)
        [[ $# -lt 2 ]] && usage
        MODE=shell run_container "$2"
        ;;
    --worktree)
        [[ $# -lt 3 ]] && { echo "Usage: claude-in-container --worktree <project> <name> [claude args...]"; exit 1; }
        project="$2"
        INSTANCE_NAME="$3"
        shift 3
        MODE=worktree run_container "$project" "$@"
        ;;
    --review)
        [[ $# -lt 2 ]] && { echo "Usage: claude-in-container --review <PR-URL> [claude args...]"; exit 1; }
        pr_url="$2"
        shift 2
        # Parse GitHub PR URL: https://github.com/<owner>/<repo>/pull/<number>
        if [[ "$pr_url" =~ github\.com/([^/]+)/([^/]+)/pull/([0-9]+) ]]; then
            pr_owner="${BASH_REMATCH[1]}"
            pr_repo="${BASH_REMATCH[2]}"
            pr_num="${BASH_REMATCH[3]}"
        else
            echo "Error: invalid PR URL: $pr_url" >&2
            echo "Expected: https://github.com/<owner>/<repo>/pull/<number>" >&2
            exit 1
        fi
        project=$(find_or_clone_project "$pr_owner" "$pr_repo")
        INSTANCE_NAME="pr-${pr_num}"
        MODE=worktree run_container "$project" "$@"
        ;;
    --list)
        list_containers
        ;;
    --stop)
        [[ $# -lt 3 ]] && { echo "Usage: claude-in-container --stop <project> <name>"; exit 1; }
        stop_worktree "$2" "$3"
        ;;
    --prune)
        [[ $# -lt 2 ]] && { echo "Usage: claude-in-container --prune <project>"; exit 1; }
        prune_worktrees "$2"
        ;;
    -h|--help)
        usage
        ;;
    *)
        run_container "$@"
        ;;
esac
